<?xml version="1.0"?>
<package format="3">
  <name>ground_agent</name>  
  <version>0.0.0</version>
  <description>ROS2 Python package for the ground agent in multi-agent mining system</description>

  <maintainer email="ucabskr@ucl.ac.uk">Somi Murthy</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <exec_depend>rclpy</exec_depend>
  <exec_depend>tf2_ros</exec_depend>

   <!-- MoveIt core -->
  <exec_depend>moveit_ros_move_group</exec_depend>
  <exec_depend>moveit_kinematics</exec_depend>
  <exec_depend>moveit_planners</exec_depend>
  <exec_depend>moveit_simple_controller_manager</exec_depend>
  <exec_depend>moveit_ros_visualization</exec_depend>

  <!-- Utils generated by the wizard -->
  <exec_depend>moveit_configs_utils</exec_depend>

  <!-- TF and state publishers -->
  <exec_depend>robot_state_publisher</exec_depend>
  <exec_depend>joint_state_publisher</exec_depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <build_depend>shared_interfaces</build_depend>
  <exec_depend>shared_interfaces</exec_depend>

  <build_depend>shared_infrastructure</build_depend>
  <exec_depend>shared_infrastructure</exec_depend>
  
  <export>
    <build_type>ament_cmake</build_type>
  </export>

</package>
