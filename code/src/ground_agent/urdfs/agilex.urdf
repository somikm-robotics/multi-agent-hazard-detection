  <!-- IMU Sensor as standalone model attached to base_link -->
  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-5" iyy="1e-5" izz="1e-5" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <collision>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>

    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="white" />
    </visual>

  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <gazebo reference="imu_link">
    <sensor name="GazeboIMU" type="imu">
        <always_on>1</always_on>
        <update_rate>100.0</update_rate>
        <visualize>true</visualize>
        <topic>agilex/imu/data</topic>
        <frame_id>agilex_diff_drive/base_link</frame_id>
        <ignition_frame_id>agilex_diff_drive/base_link</ignition_frame_id>
        <imu>
            <orientation_reference_frame>
                <localization>ENU</localization>
            </orientation_reference_frame>
        </imu>
    </sensor>
  </gazebo>
  
