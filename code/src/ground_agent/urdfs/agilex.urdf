<!-- Lidar link rigidly attached to base_link -->
<link name="gpu_lidar">
  <inertial>
    <mass value="0.005"/>
    <inertia ixx="8.33e-06" iyy="8.33e-06" izz="8.33e-06" ixy="0" ixz="0" iyz="0"/>
  </inertial>
  <visual>
    <geometry><cylinder radius="0.03" length="0.01"/></geometry>
    <material name="black"/>
  </visual>
  <collision>
    <geometry><cylinder radius="0.03" length="0.01"/></geometry>
  </collision>
</link>

<joint name="gpu_lidar_joint" type="fixed">
  <parent link="base_link"/>
  <child  link="gpu_lidar"/>
  <!-- offset of the sensor relative to the robot base -->
  <origin xyz="0.50 0 1.80" rpy="0 0 0"/>
</joint>

<!-- Gazebo GPU-LIDAR sensor -->
<gazebo reference="gpu_lidar">
  <sensor name="gpu_lidar" type="gpu_lidar">
    <update_rate>10</update_rate>
    <pose>0 0 0 0 0 0</pose>

    <ray>
      <scan>
        <horizontal>
          <samples>720</samples>
          <min_angle>-1.5708</min_angle>
          <max_angle> 1.5708</max_angle>
        </horizontal>
      </scan>
      <range><min>0.1</min><max>10.0</max></range>
    </ray>

    <!-- Make Gazebo stamp LaserScan with 'gpu_lidar' -->
    <!-- <frame_name>agilex_diff_drive_gpu_lidar</frame_name> -->
    <!-- <frame_name>gpu_lidar</frame_name> -->
    <frame_name>agilex_diff_drive/base_link/gpu_lidar</frame_name>

    <topic>/scan</topic>
    <always_on>1</always_on>
    <visualize>true</visualize>
  </sensor>
   <!-- (2) Gazebo-ROS bridge for the lidar  -->
  <!--     Fortress uses libgazebo_ros_ray_sensor.so for 2-D lidars        -->
  <plugin name="gpu_laser_ros" filename="libgazebo_ros_ray_sensor.so">
    <!-- must match the TF frame you use everywhere else -->
    <frame_name>agilex_diff_drive/base_link/gpu_lidar</frame_name>

    <!-- ROS topic to publish -->
    <topicName>/scan</topicName>

    <!-- Pass ROS arguments (use_sim_time!) to the plugin -->
    <ros>
      <!-- you can add remaps / namespace here too -->
      <arguments>--ros-args -p use_sim_time:=true</arguments>
    </ros>
  </plugin>
</gazebo>


<!-- GNSS  -->
<link name="gnss_link">
  <collision>
    <geometry>
      <sphere radius="0.05"/>
    </geometry>
  </collision>
  <visual>
    <geometry>
      <sphere radius="0.05"/>
    </geometry>
    <material name="black" />
  </visual>
  <inertial>
    <origin xyz="0 0 0.1" rpy="0.3 1.6 -0.4"/>
    <mass value="0.005"/>
    <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
  </inertial>
</link>

<joint name="gnss_joint" type="fixed">
  <origin xyz="0 0 -0.05" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="gnss_link"/>
</joint>

  <gazebo reference="gnss_link">
      <sensor name="GazeboNavSat" type="navsat">
          <always_on>1</always_on>
          <update_rate>25.0</update_rate>
          <visualize>true</visualize>
          <topic>gps/fix</topic>
      </sensor>
  </gazebo>
  
  <!-- camera-->
  <link name="rgb_cam_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.04"/>
      <inertia 
        ixx="2e-5" iyy="2e-5" izz="2e-5"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="rgb_cam_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="rgb_cam_link"/>
    <origin xyz="0.38 -0.24 0.15" rpy="0 0.18 -1.5708"/>
  </joint>

  <gazebo reference="rgb_cam_link">
    <sensor name="rgb_cam" type="camera">
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.3962634</horizontal_fov> <!-- 80 deg -->
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>30.0</far>
        </clip>
      </camera>

      <!-- Gazebo ROS 2 camera bridge plugin -->
      <plugin name="rgb_ros_bridge" filename="libgazebo_ros_camera.so">
        <ros>
          <arguments>--ros-args -p use_sim_time:=true</arguments>
        </ros>
        <camera_name>rgb_cam</camera_name>
        <image_topic>/agilex_diff_drive/camera/color/image_raw</image_topic>
        <info_topic>/agilex_diff_drive/camera/color/camera_info</info_topic>
        <frame_name>agilex_diff_drive/rgb_cam_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>
  

  <!-- === ros2_control Block Required by controller_manager === -->
  <ros2_control name="agilex_system" type="system">
    <hardware>
      
       Fortress namespace 
    
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      <param name="position_proportional_gain">0.1</param>
      <param name="velocity_proportional_gain">100.0</param>
    </hardware>
    <joint name="front_left_wheel">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
      <param name="velocity_kp">100.0</param>
      <param name="velocity_ki">0.0</param>
      <param name="velocity_kd">0.0</param>
    </joint>
    <joint name="rear_left_wheel">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
      <param name="velocity_kp">100.0</param>
      <param name="velocity_ki">0.0</param>
      <param name="velocity_kd">0.0</param>
    </joint>
    <joint name="front_right_wheel">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
      <param name="velocity_kp">100.0</param>
      <param name="velocity_ki">0.0</param>
      <param name="velocity_kd">0.0</param>
    </joint>
    <joint name="rear_right_wheel">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
      <param name="velocity_kp">100.0</param>
      <param name="velocity_ki">0.0</param>
      <param name="velocity_kd">0.0</param>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <!-- <ros>
        <namespace>$(arg namespace)</namespace>   
      </ros> -->
      <!-- Path to the controller YAML   -->
      <parameters>
                /root/ros2_ws/install/share/ground_agent/config/agilex_diff_drive_controller.yaml
      </parameters>
    </plugin>
  </gazebo>

</robot>
