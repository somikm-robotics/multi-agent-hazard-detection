      </visual>

      <collision name="collision">
        <geometry>
          <mesh>
            <uri>model://mining_terrain_overlay/meshes/mining_terrain_scaled_reversed_clean.dae</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </collision>
    </link>
